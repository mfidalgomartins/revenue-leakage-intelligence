# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Tool caches
.pytest_cache/
.cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDE/editor
.vscode/
.idea/
.claude/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Data files (keep folders only)
data/raw/**
data/processed/**
!data/raw/.gitkeep
!data/processed/.gitkeep

# Generated outputs (keep folders only)
outputs/**
!outputs/.gitkeep
!outputs/charts/.gitkeep
!outputs/charts/analysis/.gitkeep
!outputs/charts/publication/.gitkeep
!outputs/reports/.gitkeep

# Dashboards: keep only executive version
dashboard/*.html
!dashboard/executive_dashboard.html
